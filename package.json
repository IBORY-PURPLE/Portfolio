{
  "name": "song-chaewoo-internship-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static portfolio website for internship applications.",
  "scripts": {
    "dev": "node scripts/local-dev-server.cjs",
    "start": "node scripts/local-dev-server.cjs",
    "build": "tsc --noEmit && vite build --configLoader native",
