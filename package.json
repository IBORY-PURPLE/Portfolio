    "preview": "vite preview --configLoader native --host 127.0.0.1 --port 4174",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  }
}
